.SH NAME
nlsh - Natural Language Shell — talk to your system naturally


.SH SYNOPSIS
\fBnlsh [query] [flags]\fP


.SH DESCRIPTION
nlsh is a local LLM-powered shell assistant. Uses llama.cpp for on-device inference — no cloud, no HTTP server.


.SH OPTIONS
\fB--ctx-size\fP=4096
	context size in tokens

.PP
\fB--dry-run\fP[=false]
	show commands without executing them

.PP
\fB--gpu-layers\fP=16
	number of layers offloaded to GPU (0 = CPU only)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for nlsh

.PP
\fB--max-tokens\fP=512
	max tokens in model response

.PP
\fB--model\fP=""
	path to GGUF model file

.PP
\fB--shell\fP="powershell"
	shell for command execution

.PP
\fB--temperature\fP=0.2
	sampling temperature

.PP
\fB--threads\fP=12
	number of inference threads

.PP
\fB--top-p\fP=0.9
	top-p sampling threshold


