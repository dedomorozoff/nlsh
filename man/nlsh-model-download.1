.SH NAME
nlsh-model-download - Download a model (URL or from list)


.SH SYNOPSIS
\fBnlsh model download [number, name, or URL] [flags]\fP


.SH DESCRIPTION
Downloads a GGUF model. You can specify:
  a number from the list (nlsh model list)
  a model name from the list
  a direct URL to a .gguf file


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for download

.PP
\fB--set-default\fP[=false]
	Set as default model


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--ctx-size\fP=4096
	context size in tokens

.PP
\fB--dry-run\fP[=false]
	show commands without executing them

.PP
\fB--gpu-layers\fP=16
	number of layers offloaded to GPU (0 = CPU only)

.PP
\fB--max-tokens\fP=512
	max tokens in model response

.PP
\fB--model\fP=""
	path to GGUF model file

.PP
\fB--shell\fP="powershell"
	shell for command execution

.PP
\fB--temperature\fP=0.2
	sampling temperature

.PP
\fB--threads\fP=12
	number of inference threads

.PP
\fB--top-p\fP=0.9
	top-p sampling threshold


